{
  "name": "light-mate",
  "displayName": "Light Mate",
  "publisher": "himeditator",
  "icon": "assets/light-mate.png",
  "description": "A lightweight LLM agent extension for VS Code, handling lightweight tasks with less token cost.",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/HiMeditator/light-mate"
  },
  "homepage": "https://github.com/HiMeditator/light-mate",
  "bugs": {
    "url": "https://github.com/HiMeditator/light-mate/issues"
  },
  "qna": "https://github.com/HiMeditator/light-mate/issues",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "galleryBanner": {
    "color": "#1A1A1A",
    "theme": "dark"
  },
  "categories": [
    "AI",
    "Chat",
    "Education",
    "Machine Learning"
  ],
  "keywords": [
    "copilot",
    "agent",
    "openai",
    "ollama",
    "chat",
    "LLM"
  ],
  "activationEvents": [],
  "main": "./dist/extension/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "light-mate",
          "title": "%extension.name%",
          "icon": "assets/light-mate-sidebar.png"
        }
      ]
    },
    "views": {
      "light-mate": [
        {
          "type": "webview",
          "id": "light-mate.chat",
          "name": "%extension.name%",
          "icon": "assets/icons/light-mate-sidebar.png"
        }
      ]
    },
    "commands": [
      {
        "command": "light-mate.settings.open",
        "title": "%cmd.settings.open%",
        "icon": "$(gear)"
      },
      {
        "command": "light-mate.config.open",
        "title": "%cmd.config.open%",
        "icon": "$(json)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "light-mate.settings.open",
          "when": "view == light-mate.chat",
          "group": "navigation@2"
        },
        {
          "command": "light-mate.config.open",
          "when": "view == light-mate.chat",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "%extension.name%",
      "properties": {
        "lightMate.sendRequestShortcut": {
          "type": "string",
          "enum": [
            "Ctrl+Enter",
            "Enter"
          ],
          "default": "Ctrl+Enter",
          "markdownDescription": "%desc.sendRequestShortcut%",
          "order": 0
        },
        "lightMate.codeHighlightTheme": {
          "type": "string",
          "enum": [
            "github",
            "arduino-light",
            "qtcreator-light",
            "androidstudio",
            "github-dark",
            "github-dark-dimmed"
          ],
          "default": "github",
          "markdownDescription": "%desc.codeHighlightTheme%",
          "order": 1
        },
        "lightMate.chat.useDefaultSystemPrompt": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%desc.chat.useDefaultSystemPrompt%",
          "order": 100
        },
        "lightMate.chat.continuousChat": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%desc.chat.continuousChat%",
          "order": 101
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "vsce:package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "~22.19.17",
    "@types/vscode": "^1.80.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "ollama": "^0.6.3",
    "openai": "^6.34.0"
  }
}
